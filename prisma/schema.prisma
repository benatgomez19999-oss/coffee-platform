generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 🌱 CORE DOMAIN (COFFEE SUPPLY CHAIN)
//////////////////////////////////////////////////////

model Producer {
  id        String   @id @default(uuid())
  name      String
  country   String
  createdAt DateTime @default(now())
  farms     Farm[]
}

model Farm {
  id         String     @id @default(uuid())
  name       String
  altitude   Int?
  producerId String
  producer   Producer   @relation(fields: [producerId], references: [id])
  lots       GreenLot[]
}

model GreenLot {
  id           String       @id @default(uuid())
  farmId       String
  variety      String
  process      ProcessType
  harvestYear  Int
  quantityKg   Float
  createdAt    DateTime     @default(now())

  farm         Farm         @relation(fields: [farmId], references: [id])
  purchases    Purchase[]
  roastBatches RoastBatch[]
}

model Purchase {
  id          String   @id @default(uuid())
  lotId       String
  quantityKg  Float
  pricePerKg  Float
  purchasedAt DateTime
  createdAt   DateTime @default(now())

  lot         GreenLot @relation(fields: [lotId], references: [id])
}

model RoastProfile {
  id      String       @id @default(uuid())
  name    String
  notes   String?
  batches RoastBatch[]
}

model RoastBatch {
  id             String        @id @default(uuid())
  greenLotId     String
  roastProfileId String?
  inputKg        Float
  outputKg       Float
  yieldPercent   Float?
  lossPercent    Float?
  roastedAt      DateTime
  createdAt      DateTime      @default(now())

  greenLot       GreenLot      @relation(fields: [greenLotId], references: [id])
  roastProfile   RoastProfile? @relation(fields: [roastProfileId], references: [id])
  roastedBatch   RoastedBatch?
}

model RoastedBatch {
  id           String      @id @default(uuid())
  roastBatchId String      @unique
  quantityKg   Float
  bagSizeKg    Float       @default(20)
  bagCount     Int
  createdAt    DateTime    @default(now())

  roastBatch   RoastBatch  @relation(fields: [roastBatchId], references: [id])
  contracts    Contract[]
  orders       OrderItem[]
}

//////////////////////////////////////////////////////
// 🏢 MULTI-TENANT (COMPANIES)
//////////////////////////////////////////////////////

model Company {
  id        String     @id @default(uuid())
  name      String
  country   String

  // 🔥 NUEVO (onboarding data)
  phone        String?
  address      String?
  vat          String?   // CIF
  contactName  String?

  createdAt DateTime   @default(now())

  users     User[]
  contracts Contract[]
  orders    Order[]
}

//////////////////////////////////////////////////////
// 📄 CONTRACTS & ORDERS
//////////////////////////////////////////////////////

model Contract {
  id              String           @id @default(uuid())
  companyId       String
  roastedBatchId  String?

  monthlyVolumeKg Float
  durationMonths  Int
  remainingMonths Int

  pricePerBag     Float
  bagSizeKg       Float            @default(20)
  bagsPerDelivery Int

  // 🔥 NUEVO → precio mensual total
  monthlyPrice    Float

  startDate       DateTime
  endDate         DateTime?
  nextExecution   DateTime?

  status          ContractStatus   @default(PENDING)
  createdAt       DateTime         @default(now())

  // 🔥 OPCIONAL (MUY RECOMENDADO para Stripe)
  stripeSubscriptionId String?
  stripeCustomerId     String?

  company         Company          @relation(fields: [companyId], references: [id])
  roastedBatch    RoastedBatch?    @relation(fields: [roastedBatchId], references: [id])

  orders          Order[]
  signatureTokens SignatureToken[]
}

model Order {
  id         String      @id @default(uuid())
  companyId  String
  contractId String?
  status     OrderStatus
  createdAt  DateTime    @default(now())

  company    Company     @relation(fields: [companyId], references: [id])
  contract   Contract?   @relation(fields: [contractId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id             String       @id @default(uuid())
  orderId        String
  roastedBatchId String
  bags           Int
  pricePerBag    Float

  order          Order        @relation(fields: [orderId], references: [id])
  roastedBatch   RoastedBatch @relation(fields: [roastedBatchId], references: [id])
}

//////////////////////////////////////////////////////
// ✍️ SIGNATURE FLOW (OTP READY)
//////////////////////////////////////////////////////

model SignatureToken {
  token          String   @id

  // 🔥 ahora opcional (porque puede no existir aún)
  contractId     String?

  // 🔥 NUEVO: guardamos el draft completo
  contractDraft  Json?

  // 🔥 NUEVO: create | amend
  mode           String?

  phone          String
  expiresAt      DateTime

  verified       Boolean  @default(false)
  signed         Boolean  @default(false)

  createdAt      DateTime @default(now())

  // 🔥 relación opcional
  contract       Contract? @relation(fields: [contractId], references: [id])
}

//////////////////////////////////////////////////////
// 🔐 AUTH SYSTEM (NUEVO — PRO LEVEL)
//////////////////////////////////////////////////////

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?

  phone        String?
  role         String?

  twoFactorEnabled Boolean @default(false)

  // 🔥 NUEVO
  onboardingCompleted Boolean @default(false)

  companyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company? @relation(fields: [companyId], references: [id])

  otpCodes OTPCode[]

  @@index([companyId])
}

//////////////////////////////////////////////////////
// 📧 EMAIL VERIFICATION
//////////////////////////////////////////////////////

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique

  email     String
  password  String
  name      String?

  // 🔥 NUEVO
  phone     String?
  companyId String?

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////////////////////////////
// 🔑 PASSWORD RESET
//////////////////////////////////////////////////////

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique

  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////////////////////////////
// 📲 2FA (OTP SMS)
//////////////////////////////////////////////////////

model OTPCode {
  id        String   @id @default(uuid())
  code      String
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, code])
}

//////////////////////////////////////////////////////
// 📊 ENUMS
//////////////////////////////////////////////////////

enum ProcessType {
  WASHED
  NATURAL
  HONEY
  ANAEROBIC
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
}

enum ContractStatus {
  PENDING
  AWAITING_SIGNATURE
  SIGNED          // (firma hecha, sin pago)
  PAYMENT_PENDING // (listo para pagar)
  ACTIVE
  PAST_DUE        // (fallo de pago)
  COMPLETED
  CANCELLED
}