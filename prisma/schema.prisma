generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 🌱 CORE DOMAIN (COFFEE SUPPLY CHAIN)
//////////////////////////////////////////////////////

model Producer {
  id        String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // 🔥 RELACIÓN CON USER (CLAVE DEL SISTEMA)
  //////////////////////////////////////////////////////
  userId    String   @unique

  name      String
  country   String
  createdAt DateTime @default(now())

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  farms       Farm[]
  user        User                 @relation(fields: [userId], references: [id])
  fulfilments ProducerFulfilment[]
}

model Farm {
  id         String     @id @default(uuid())
  name       String
  altitude   Int?
  region     String?
  producerId String
  producer   Producer   @relation(fields: [producerId], references: [id])
  lots       GreenLot[]

  //////////////////////////////////////////////////////
  // 🧠 STORIES
  //////////////////////////////////////////////////////

  stories    FarmStory[]
}

model ProducerLotDraft {
  id        String   @id @default(uuid())

  producerId String
  farmId     String

  //////////////////////////////////////////////////////
  // 🔢 TRACEABILITY (CRÍTICO)
  //////////////////////////////////////////////////////

  lotNumber String @unique

  //////////////////////////////////////////////////////
  // 🌱 INPUT DEL PRODUCTOR
  //////////////////////////////////////////////////////

  name        String?
  variety     String
  process     ProcessType
  harvestYear Int

  //////////////////////////////////////////////////////
  // 📦 VOLUME (PERGAMINO → GREEN ESTIMATION)
  //////////////////////////////////////////////////////

  parchmentKg Float

  estimatedGreenKg Float

  //////////////////////////////////////////////////////
  // 📊 CONVERSION TRACKING (MUY IMPORTANTE)
  //////////////////////////////////////////////////////

  conversionRate Float @default(0.8)

  //////////////////////////////////////////////////////
  // 📦 STATUS
  //////////////////////////////////////////////////////

  status LotDraftStatus @default(PENDING)

  //////////////////////////////////////////////////////
  // 🚚 SAMPLE SHIPPING STATUS
  //////////////////////////////////////////////////////

  sampleShippingStatus SampleShippingStatus?

  //////////////////////////////////////////////////////
  // 🔗 RELATION (cuando se valida)
  //////////////////////////////////////////////////////

    greenLot   GreenLot? @relation(fields: [greenLotId], references: [id])
    greenLotId String? @unique

  //////////////////////////////////////////////////////
  // 🕓 META
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())
}


//////////////////////////////////////////////////////
// 🌱 GREEN LOT (MARKETPLACE READY)
//////////////////////////////////////////////////////

model GreenLot {
  id           String       @id @default(uuid())
  farmId       String

  // =====================================================
  // 🔢 TRACEABILITY
  // =====================================================

  lotNumber    String       @unique

  // =====================================================
  // PRODUCT INFO
  // =====================================================

  name         String?
  description  String?
  imageUrl     String?

  variety      String
  process      ProcessType
  harvestYear  Int

  scaScore     Float?
  altitude     Int?

  // =====================================================
  // ROAST YIELD ESTIMATE (green → roasted)
  // Set by partner during lot evaluation.
  // Fallback: process-based default in resolveRoastYield().
  // =====================================================

  estimatedRoastYield Float?

  // =====================================================
  // VOLUME
  // =====================================================

  totalKg      Float
  availableKg  Float

  // =====================================================
  // PRICING
  // =====================================================

  pricePerKg   Float
  currency     String       @default("EUR")

  // =====================================================
  // STATUS
  // =====================================================

  status       LotStatus    @default(DRAFT)

  createdAt    DateTime     @default(now())

  // =====================================================
  // RELATIONS
  // =====================================================

  farm         Farm         @relation(fields: [farmId], references: [id])
  purchases    Purchase[]
  roastBatches RoastBatch[]

  producerDraft ProducerLotDraft?

  // 💰 PRICING SNAPSHOT (1:1)
  pricingSnapshot PricingSnapshot?

  // 📦 PRODUCER FULFILMENT (1:1)
  fulfilment    ProducerFulfilment?

  // 📄 CONTRACTS (reverse relation)
  contracts     Contract[]

  // 🧠 DEMAND INTENTS (reverse relation)
  demandIntents DemandIntent[]
}

enum LotStatus {
  DRAFT
  PUBLISHED
  RESERVED
  SOLD
}



model Purchase {
  id          String   @id @default(uuid())
  lotId       String
  quantityKg  Float
  pricePerKg  Float
  purchasedAt DateTime
  createdAt   DateTime @default(now())

  lot         GreenLot @relation(fields: [lotId], references: [id])
}

model RoastProfile {
  id      String       @id @default(uuid())
  name    String
  notes   String?
  batches RoastBatch[]
}

model RoastBatch {
  id             String        @id @default(uuid())
  greenLotId     String
  roastProfileId String?
  inputKg        Float
  outputKg       Float
  yieldPercent   Float?
  lossPercent    Float?
  roastedAt      DateTime
  createdAt      DateTime      @default(now())

  greenLot       GreenLot      @relation(fields: [greenLotId], references: [id])
  roastProfile   RoastProfile? @relation(fields: [roastProfileId], references: [id])
  roastedBatch   RoastedBatch?
}

model RoastedBatch {
  id           String      @id @default(uuid())
  roastBatchId String      @unique
  quantityKg   Float
  bagSizeKg    Float       @default(20)
  bagCount     Int
  createdAt    DateTime    @default(now())

  roastBatch   RoastBatch  @relation(fields: [roastBatchId], references: [id])
  contracts    Contract[]
  orders       OrderItem[]
}

//////////////////////////////////////////////////////
// 💰 PRICING ENGINE
//////////////////////////////////////////////////////

model PricingSnapshot {
  id        String   @id @default(uuid())

  lotId     String   @unique
  lot       GreenLot @relation(fields: [lotId], references: [id])

  // 💸 precio pagado al productor
  producerPricePerKg Float

  // 💰 precio venta cliente
  clientPricePerKg   Float

  // 📊 margen (opcional pero útil)
  marginPerKg        Float

  // 🧠 versionado del algoritmo
  pricingVersion     String

  //////////////////////////////////////////////////////
  // 🧠 PRICING BREAKDOWN (CRÍTICO)
  //////////////////////////////////////////////////////

  breakdown Json?

  //////////////////////////////////////////////////////
  // 📊 METADATA (FUTURO / DEBUG)
  //////////////////////////////////////////////////////

  // input original del cálculo (opcional)
  context   Json?

  createdAt DateTime @default(now())
}

model PricingRule {
  id String @id @default(uuid())

  // 🎯 condiciones
  minSca Float?
  maxSca Float?

  minAltitude Int?
  maxAltitude Int?

  variety String?
  process ProcessType?

  // 💰 outputs
  producerPricePerKg Float
  clientPricePerKg   Float

  // 🧠 prioridad
  priority Int

  active Boolean @default(true)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// 🏢 MULTI-TENANT (COMPANIES)
//////////////////////////////////////////////////////

model Company {
  id        String     @id @default(uuid())
  name      String
  country   String

  // 🔥 NUEVO (onboarding data)
  phone        String?
  address      String?
  vat          String?   // CIF
  contactName  String?
  businessName       String?
  legalCompanyName   String?

  createdAt DateTime   @default(now())

  users         User[]
  contracts     Contract[]
  orders        Order[]
  demandIntents DemandIntent[]
}

//////////////////////////////////////////////////////
// 📄 CONTRACTS & ORDERS
//////////////////////////////////////////////////////

model Contract {
  id              String           @id @default(uuid())
  companyId       String
  roastedBatchId  String?

  // SUPPLY TARGET — direct link to the coffee this contract is for
  greenLotId      String?

  // VOLUME — monthlyVolumeKg is in ROASTED kg (client commitment).
  // monthlyGreenKg is the green equivalent for supply accounting.
  monthlyVolumeKg Float
  monthlyGreenKg  Float?
  durationMonths  Int
  remainingMonths Int

  // LOCKED PRICING — per ROASTED kg, frozen at contract creation.
  // Derived: PricingSnapshot.clientPricePerKg / roastYieldAtCreation.
  // Survives same-coffee amends. Replaced only on coffee switch.
  lockedPricePerKg    Float?
  roastYieldAtCreation Float?

  pricePerBag     Float
  bagSizeKg       Float            @default(20)
  bagsPerDelivery Int

  // 🔥 NUEVO → precio mensual total
  monthlyPrice    Float

  startDate       DateTime
  endDate         DateTime?
  nextExecution   DateTime?

  status          ContractStatus   @default(PENDING)
  createdAt       DateTime         @default(now())

  // 🔥 OPCIONAL (MUY RECOMENDADO para Stripe)
  stripeSubscriptionId String?
  stripeCustomerId     String?

  company         Company          @relation(fields: [companyId], references: [id])
  roastedBatch    RoastedBatch?    @relation(fields: [roastedBatchId], references: [id])
  greenLot        GreenLot?        @relation(fields: [greenLotId], references: [id])

  orders          Order[]
  signatureTokens SignatureToken[]
  demandIntents   DemandIntent[]
}

model Order {
  id         String      @id @default(uuid())
  companyId  String
  contractId String?
  status     OrderStatus
  createdAt  DateTime    @default(now())

  company     Company              @relation(fields: [companyId], references: [id])
  contract    Contract?            @relation(fields: [contractId], references: [id])
  items       OrderItem[]
  fulfilments ProducerFulfilment[]
}

model OrderItem {
  id             String       @id @default(uuid())
  orderId        String
  roastedBatchId String
  bags           Int
  pricePerBag    Float

  order          Order        @relation(fields: [orderId], references: [id])
  roastedBatch   RoastedBatch @relation(fields: [roastedBatchId], references: [id])
}

//////////////////////////////////////////////////////
// 🧠 DEMAND INTENT
// Persistent record of demand evaluation.
// Created when a client requests volume (create or amend).
// Consumed when a contract is created/amended against it.
// Phase 1: schema exists but is not yet required by routes.
//////////////////////////////////////////////////////

model DemandIntent {
  id              String              @id @default(uuid())
  companyId       String

  type            DemandIntentType
  contractId      String?

  greenLotId      String?

  // VOLUME — requestedKg and offeredKg are ROASTED (client-facing).
  // deltaKg is GREEN (supply reservation, used by getContractableSupply).
  requestedKg     Float
  deltaKg         Float
  offeredKg       Float?

  // CONVERSION SNAPSHOT — yield used to convert roasted↔green at eval time.
  roastYieldAtEval Float?

  priceLocked     Boolean
  previewPricePerKg Float?

  semaphore       String
  riskScore       Float
  availableAtEval Float

  // DEFERRED FLOW — autoExecute enables WAITING → OPEN → contract
  // when supply becomes available, without manual client confirmation.
  autoExecute     Boolean             @default(false)
  notifiedAt      DateTime?

  status          DemandIntentStatus  @default(OPEN)
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime            @default(now())

  company         Company             @relation(fields: [companyId], references: [id])
  contract        Contract?           @relation(fields: [contractId], references: [id])
  greenLot        GreenLot?           @relation(fields: [greenLotId], references: [id])

  @@index([companyId])
  @@index([greenLotId, status])
  @@index([status, expiresAt])
}

enum DemandIntentType {
  CREATE
  AMEND
}

enum DemandIntentStatus {
  OPEN
  COUNTERED
  WAITING
  CONSUMED
  EXPIRED
  REJECTED
  CANCELLED
}

//////////////////////////////////////////////////////
// ✍️ SIGNATURE FLOW (OTP READY)
//////////////////////////////////////////////////////

model SignatureToken {
  token          String   @id

  // 🔥 ahora opcional (porque puede no existir aún)
  contractId     String?

  // 🔥 NUEVO: guardamos el draft completo
  contractDraft  Json?

  // 🔥 NUEVO: create | amend
  mode           String?

  phone          String
  expiresAt      DateTime

  verified       Boolean  @default(false)
  signed         Boolean  @default(false)

  createdAt      DateTime @default(now())

  // 🔥 relación opcional
  contract       Contract? @relation(fields: [contractId], references: [id])
}

//////////////////////////////////////////////////////
// 🔐 AUTH SYSTEM (NUEVO — PRO LEVEL)
//////////////////////////////////////////////////////

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?

  phone        String?
  role         String?

  twoFactorEnabled Boolean @default(false)

  onboardingCompleted Boolean @default(false)

  companyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company? @relation(fields: [companyId], references: [id])

  otpCodes OTPCode[]

  @@index([companyId])

  //////////////////////////////////////////////////////
  //  RELACIÓN CON PRODUCER
  //////////////////////////////////////////////////////

  producer Producer?
  
}

//////////////////////////////////////////////////////
// 📧 EMAIL VERIFICATION
//////////////////////////////////////////////////////

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique

  email     String
  password  String
  name      String?

  // 🔥 NUEVO
  phone     String?
  companyId String?

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////////////////////////////
// 🔑 PASSWORD RESET
//////////////////////////////////////////////////////

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique

  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////////////////////////////
// 📲 2FA (OTP SMS)
//////////////////////////////////////////////////////

model OTPCode {
  id        String   @id @default(uuid())
  code      String
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, code])
}

//////////////////////////////////////////////////////
// 🌿 FARM STORY (AI + MANUAL)
//////////////////////////////////////////////////////

model FarmStory {
  id         String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // 🔗 RELATIONS
  //////////////////////////////////////////////////////

  farmId     String
  farm       Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // ✍️ CONTENT
  //////////////////////////////////////////////////////

  content    String

  //////////////////////////////////////////////////////
  // 🧠 SOURCE (AI vs MANUAL)
  //////////////////////////////////////////////////////

  source     StorySource @default(AI)

  //////////////////////////////////////////////////////
  // 📦 STATUS (para workflow futuro)
  //////////////////////////////////////////////////////

  status     StoryStatus @default(DRAFT)

  //////////////////////////////////////////////////////
  // 🔁 VERSIONING (MUY IMPORTANTE)
  //////////////////////////////////////////////////////

  version    Int        @default(1)

  //////////////////////////////////////////////////////
  // 🕓 META
  //////////////////////////////////////////////////////

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

//////////////////////////////////////////////////////
// 📊 ENUMS
//////////////////////////////////////////////////////

enum ProcessType {
  WASHED
  NATURAL
  HONEY
  ANAEROBIC
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
}

enum ContractStatus {
  PENDING
  AWAITING_SIGNATURE
  SIGNED          // (firma hecha, sin pago)
  PAYMENT_PENDING // (listo para pagar)
  ACTIVE
  PAST_DUE        // (fallo de pago)
  COMPLETED
  CANCELLED
}

enum LotDraftStatus {
  PENDING
  SAMPLE_REQUESTED
  IN_REVIEW
  VERIFIED
  REJECTED
}

enum SampleShippingStatus {
  PICKUP_REQUESTED
  PICKUP_SCHEDULED
  IN_TRANSIT
  DELIVERED
}

enum StorySource {
  AI
  MANUAL
}

enum MarketSignalSource {
  MANUAL
  API_FEED
  INTERNAL_COMPUTE
  AI_SYSTEM
}

//////////////////////////////////////////////////////
// 📊 MARKET SIGNAL SNAPSHOT
// Optional market context for producer pricing.
// Read by verifyLotService at lot verification time.
// Must never be a hard dependency — pricing works
// without it (deterministic fallback).
//////////////////////////////////////////////////////

model MarketSignalSnapshot {
  id          String            @id @default(uuid())

  // C-market arabica reference price (ICE, cents/lb)
  cPrice      Float

  // Normalized demand pressure multiplier (0.8–1.2)
  demandIndex Float

  // Provenance of this snapshot
  source      MarketSignalSource

  // Only one snapshot should be active at a time
  isActive    Boolean           @default(true)

  // Optional operator note (e.g. "ICE July settlement")
  note        String?

  validFrom   DateTime          @default(now())
  expiresAt   DateTime?

  createdAt   DateTime          @default(now())
}

enum StoryStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

//////////////////////////////////////////////////////
// 📦 PRODUCER FULFILMENT
// Tracks the physical dispatch lifecycle on the
// producer side. Separate from GreenLot.status
// (marketplace lifecycle) — these are independent
// state machines.
//////////////////////////////////////////////////////

enum ProducerFulfilmentStatus {
  AWAITING_CONFIRMATION
  CONFIRMED
  SACKS_MARKED_CONFIRMED
  COURIER_VERIFIED
}

model ProducerFulfilment {
  id         String                   @id @default(uuid())

  // One fulfilment task per GreenLot
  greenLotId String                   @unique
  orderId    String
  producerId String

  status     ProducerFulfilmentStatus @default(AWAITING_CONFIRMATION)

  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  greenLot   GreenLot                 @relation(fields: [greenLotId], references: [id])
  order      Order                    @relation(fields: [orderId], references: [id])
  producer   Producer                 @relation(fields: [producerId], references: [id])
}

//////////////////////////////////////////////////////
// 🩺 COMMITMENT HEALTH SNAPSHOT
//
// Audit row for the Supply & Commitment Health Monitor
// (src/internal/monitors/supplyCommitmentHealth).
//
// Append-only. Never updated. Never reused for any
// other monitor. Each row is the full record of one
// monitor run, including the deterministic
// inputFingerprint that uniquely identifies the
// snapshot of business data the run observed.
//
// DO NOT MERGE WITH MarketSignalSnapshot — that table
// belongs to the synthetic AI system being phased out;
// mixing the two would destroy the audit credibility
// this monitor is designed to establish.
//////////////////////////////////////////////////////

enum HealthSeverity {
  OK
  WATCH
  STRESSED
  CRITICAL
}

model CommitmentHealthSnapshot {
  id                String         @id @default(uuid())

  runId             String         @unique
  monitorVersion    String

  runStartedAt      DateTime
  runFinishedAt     DateTime
  durationMs        Int

  // Deterministic hash of the input snapshot used for this run.
  // Two runs with the same fingerprint observed identical inputs.
  inputFingerprint  String

  // Conservative-max rollup across the four axes.
  overallHealth     HealthSeverity
  supplyHealth      HealthSeverity
  demandHealth      HealthSeverity
  commitmentHealth  HealthSeverity
  fulfilmentHealth  HealthSeverity

  // Full report payloads.
  metrics           Json
  detectors         Json
  attribution       Json
  inputCounts       Json

  // Operator who invoked the run.
  triggeredBy       String?

  createdAt         DateTime       @default(now())

  @@index([runStartedAt])
  @@index([overallHealth])
  @@index([inputFingerprint])
}

